# Copy to .env.local and fill in from your Supabase project
# (Project Settings → API). Leave these blank to keep running in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Planning Center (optional) ──
# Create a Personal Access Token at https://api.planningcenteronline.com/oauth/applications
# These are server-only (no NEXT_PUBLIC_ prefix) so they never reach the browser.
PCO_APP_ID=
PCO_SECRET=
